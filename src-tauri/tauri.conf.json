{
  "productName": "Fry Edge Miner",
  "version": "0.2.21",
  "build": {
    "beforeBuildCommand": "npm run build",
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:5173",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "Fry Edge Miner",
        "width": 1200,
        "height": 800,
        "minWidth": 800,
        "minHeight": 600,
        "resizable": true,
        "fullscreen": false
      }
    ],
    "security": {
      "csp": null
    }
  },
  "identifier": "com.frynetworks.fem",
  "plugins": {
    "updater": {
      "endpoints": [
        "https://github.com/Fry-Foundation/fry-edge-miner/releases/latest/download/latest.json"
      ],
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IDRGMkQyMzc2MjUwOUNERkIKUldUN3pRa2xkaU10VDNyTHNwVVN0NUxNUjlndGNzbHI4UUtJRG5OcWlNOWtKQm9KbVZmd0drT0oK"
    }
  },
  "bundle": {
    "createUpdaterArtifacts": true,
    "active": true,
    "targets": "all",
    "icon": [
      "icons/icon.ico"
    ],
    "windows": {
      "webviewInstallMode": {
        "type": "embedBootstrapper",
        "silent": true
      },
      "nsis": {
        "displayLanguageSelector": false,
        "installMode": "currentUser",
        "installerHooks": "nsis-hooks.nsh"
      }
    },
    "linux": {
      "deb": {
        "depends": [
          "libwebkit2gtk-4.1-0",
          "libgtk-3-0",
          "libayatana-appindicator3-1",
          "librsvg2-2",
          "libssl3",
          "libdbus-1-3"
        ]
      }
    }
  }
}
