{
  "productName": "Fry Edge Miner",
  "version": "0.2.0",
  "build": {
    "beforeBuildCommand": "npm run build",
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:5173",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "Fry Edge Miner",
        "width": 1200,
        "height": 800,
        "minWidth": 800,
        "minHeight": 600,
        "resizable": true,
        "fullscreen": false
      }
    ],
    "security": {
      "csp": null
    }
  },
  "identifier": "com.frynetworks.fem",
  "plugins": {
    "updater": {
      "endpoints": [
        "https://github.com/Fry-Foundation/fry-edge-miner/releases/latest/download/latest.json"
      ],
      "dialog": true,
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IDU1RjdFREM3NThBMDY2MjYKUldRbVpxQll4KzMzVldSQVFXUURzL3RnVjNIcVUrYXZySFdOdlRQdWVYc2tFOEhQV2pUNFZMS04K"
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/icon.ico"
    ],
    "windows": {
      "nsis": {
        "displayLanguageSelector": false
      }
    }
  }
}
